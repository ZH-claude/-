{
  "name": "nested-api-relay",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "install:all": "npm ci --prefix apps/api && npm ci --prefix apps/web",
    "dev:api": "npm --prefix apps/api run dev",
    "dev:web": "npm --prefix apps/web run dev",
    "build": "npm --prefix apps/api run build && npm --prefix apps/web run build",
    "typecheck": "npm --prefix apps/api run typecheck && npm --prefix apps/web run typecheck",
    "qa:t10:recharge": "npm --prefix apps/api run qa:t10:recharge",
    "qa:t11:usage-logs": "npm --prefix apps/api run qa:t11:usage-logs",
    "qa:t12:pricing": "npm --prefix apps/api run qa:t12:pricing",
    "qa:t13:group-availability": "npm --prefix apps/api run qa:t13:group-availability",
    "qa:t14:notifications": "npm --prefix apps/api run qa:t14:notifications",
    "qa:t15:announcements": "npm --prefix apps/api run qa:t15:announcements",
    "qa:t16:async-tasks": "npm --prefix apps/api run qa:t16:async-tasks",
    "qa:t17:service-status": "npm --prefix apps/api run qa:t17:service-status",
    "qa:t18:rate-limits": "npm --prefix apps/api run qa:t18:rate-limits",
    "qa:t19:security-hardening": "npm --prefix apps/api run qa:t19:security-hardening",
    "qa:t20:observability": "npm --prefix apps/api run qa:t20:observability",
    "qa:profile-alignment": "npm --prefix apps/api run qa:profile-alignment",
    "seed:merchant-test-accounts": "npm --prefix apps/api run seed:merchant-test-accounts",
    "preflight:t21:prod": "node ops/deploy/preflight.mjs --env-file .env",
    "deploy:t21:prod": "sh ops/deploy/deploy.sh",
    "verify:t21:restart": "sh ops/deploy/restart-verify.sh",
    "smoke:t21:deploy": "node ops/smoke/t21-deploy-smoke.mjs",
    "start:api": "npm --prefix apps/api run start",
    "start:web": "npm --prefix apps/web run start"
  },
  "engines": {
    "node": ">=20.11.0"
  }
}
