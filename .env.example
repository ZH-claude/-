POSTGRES_USER=placeholder_user
POSTGRES_PASSWORD=placeholder_password
POSTGRES_DB=relay_station

# Use service names inside Docker Compose. Use localhost for host-machine local connections.
DATABASE_URL=postgresql://placeholder_user:placeholder_password@postgres:5432/relay_station
# If REDIS_PASSWORD is set, also set REDIS_URL to redis://:<password>@redis:6379.
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

API_PORT=3001
WEB_PORT=3000
SESSION_COOKIE_SECURE=false
ADMIN_BOOTSTRAP_USERNAME=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_FORCE_RESET=false
UPSTREAM_KEY_ENCRYPTION_SECRET=replace_with_at_least_32_random_characters
NOTIFICATION_SECRET_ENCRYPTION_SECRET=replace_with_at_least_32_random_characters
# Optional built-in health probes for /uptimeStatus.
WEB_HEALTH_URL=http://web:3000
# Optional Uptime Kuma public status page URL. Leave empty to show "not configured".
UPTIME_KUMA_STATUS_URL=
# The web app proxies browser auth requests through /api/auth/* so cookies stay same-origin.
# Keep INTERNAL_API_BASE_URL on the server side. NEXT_PUBLIC_API_BASE_URL is only a legacy fallback.
INTERNAL_API_BASE_URL=http://api:3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
PUBLIC_WEB_URL=https://app.example.com
PUBLIC_API_URL=https://api.example.com
CADDY_WEB_DOMAIN=app.example.com
CADDY_API_DOMAIN=api.example.com
ACME_EMAIL=admin@example.com

JWT_SECRET=replace_with_secure_random_string
UPSTREAM_BASE_URL=https://upstream.example.com
UPSTREAM_API_KEY=replace_with_upstream_api_key

# T21 deployment smoke test. Leave unset unless running a real deployment check.
SMOKE_WEB_URL=
SMOKE_API_URL=
SMOKE_USERNAME=
SMOKE_PASSWORD=
SMOKE_API_KEY=
SMOKE_MODEL=
SMOKE_RUN_CHAT=false
SMOKE_CHAT_BODY=
SMOKE_RECHARGE_CODE=
SMOKE_TEST_NOTIFICATION=false
SMOKE_STRICT=false
