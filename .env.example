POSTGRES_USER=placeholder_user
POSTGRES_PASSWORD=placeholder_password
POSTGRES_DB=relay_station

# Use service names inside Docker Compose. Use localhost for host-machine local connections.
DATABASE_URL=postgresql://placeholder_user:placeholder_password@postgres:5432/relay_station
# If REDIS_PASSWORD is set, also set REDIS_URL to redis://:<password>@redis:6379.
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=

API_PORT=3001
WEB_PORT=3000
SESSION_COOKIE_SECURE=false
ADMIN_BOOTSTRAP_USERNAME=
ADMIN_BOOTSTRAP_PASSWORD=
ADMIN_BOOTSTRAP_FORCE_RESET=false
# Auth abuse protection, counted per IP and action in a 60-second window.
AUTH_PHONE_LOGIN_PER_MINUTE_LIMIT=5
AUTH_PASSWORD_RECOVERY_PER_MINUTE_LIMIT=5
AUTH_PASSWORD_RESET_PER_MINUTE_LIMIT=5
# Password recovery codes are stored as hashes. Use a stable secret; changing it invalidates unexpired codes.
PASSWORD_RECOVERY_CODE_SECRET=replace_with_at_least_32_random_characters
# Local/QA may expose debugCode in /auth/password-recovery/request. Keep false in production unless intentionally testing.
AUTH_PASSWORD_RECOVERY_DEBUG_CODE=false
# Future SMS provider integration point. When unset/false, local recovery still works through explicit debug mode.
SMS_PROVIDER_ENABLED=false
SMS_PROVIDER_NAME=
# Optional local/staging helper for `npm run seed:merchant-test-accounts`.
# Do not set this in production unless intentionally creating test admin accounts.
MERCHANT_TEST_PASSWORD=
UPSTREAM_KEY_ENCRYPTION_SECRET=replace_with_at_least_32_random_characters
NOTIFICATION_SECRET_ENCRYPTION_SECRET=replace_with_at_least_32_random_characters
# Optional built-in health probes for /uptimeStatus.
WEB_HEALTH_URL=http://web:3000
# Optional Uptime Kuma public status page URL. Leave empty to show "not configured".
UPTIME_KUMA_STATUS_URL=
# The web app proxies browser auth requests through /api/auth/* so cookies stay same-origin.
# Keep INTERNAL_API_BASE_URL on the server side. NEXT_PUBLIC_API_BASE_URL is only a legacy fallback.
INTERNAL_API_BASE_URL=http://api:3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
PUBLIC_WEB_URL=https://app.example.com
PUBLIC_API_URL=https://api.example.com
PUBLIC_SITE_URL=https://newaicode.com

# Local/staging auto-translation helper.
# Production defaults to disabled. The public Google endpoint is for local/staging assistance only
# unless AUTO_TRANSLATE_ALLOW_PUBLIC_GOOGLE_IN_PRODUCTION=true is set explicitly.
# Production should use custom-http with a private/official translation service instead of long-term public Google.
# Supported values today: custom-http, google-public, disabled, none.
AUTO_TRANSLATE_PROVIDER=disabled
AUTO_TRANSLATE_DISABLED=false
AUTO_TRANSLATE_ALLOW_PUBLIC_GOOGLE_IN_PRODUCTION=false
AUTO_TRANSLATE_TIMEOUT_MS=6000
# custom-http sends POST JSON: { "sourceLanguage": "auto", "targetLanguage": "ja", "text": "..." }.
# It accepts JSON responses with translatedText, translation, text, or data.translatedText.
AUTO_TRANSLATE_CUSTOM_URL=
AUTO_TRANSLATE_CUSTOM_API_KEY=
AUTO_TRANSLATE_CUSTOM_API_KEY_HEADER=Authorization
# Publish-time draft preparation marks these languages for admin review.
# If AUTO_TRANSLATE_PROVIDER is disabled, drafts are created as status metadata without calling a public translator.
AUTO_TRANSLATE_TARGET_LANGUAGES=zh-TW,en-US,es-ES,fr-FR,de-DE,pt-BR,ja-JP,ko-KR,ru-RU,ar-EG,sw-KE,am-ET,ha-NG,yo-NG,ig-NG,zu-ZA,af-ZA,so-SO,rw-RW,om-ET,hi-IN,id-ID,tr-TR,vi-VN,th-TH,it-IT,nl-NL,pl-PL,uk-UA,ms-MY,fa-IR
# Optional JSON glossary. Brand terms are protected by default.
AUTO_TRANSLATE_GLOSSARY={"Azure Planet Relay":"Azure Planet Relay"}

CADDY_WEB_DOMAIN=app.example.com
CADDY_API_DOMAIN=api.example.com
ACME_EMAIL=admin@example.com

JWT_SECRET=replace_with_secure_random_string
UPSTREAM_BASE_URL=https://upstream.example.com
UPSTREAM_API_KEY=replace_with_upstream_api_key

# T21 deployment smoke test. Leave unset unless running a real deployment check.
SMOKE_WEB_URL=
SMOKE_API_URL=
SMOKE_USERNAME=
SMOKE_PASSWORD=
SMOKE_API_KEY=
SMOKE_MODEL=
SMOKE_RUN_CHAT=false
SMOKE_CHAT_BODY=
SMOKE_RECHARGE_CODE=
SMOKE_TEST_NOTIFICATION=false
SMOKE_STRICT=false
