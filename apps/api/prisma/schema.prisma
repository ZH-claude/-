generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  DISABLED
  RISK_LOCKED
}

enum UserRole {
  USER
  ADMIN
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AnnouncementCategory {
  ANNOUNCEMENT
  UPDATE_LOG
  USAGE_GUIDE
}

enum GroupStatus {
  ACTIVE
  DISABLED
}

enum UpstreamProviderStatus {
  ACTIVE
  DISABLED
}

enum UpstreamProviderKind {
  GENERIC
  DEEPSEEK
  RELAY
}

enum UpstreamHealthStatus {
  UNKNOWN
  HEALTHY
  UNHEALTHY
}

enum ModelStatus {
  ACTIVE
  DISABLED
}

enum ModelPricingMode {
  MANUAL
  DEEPSEEK_BASE
  RELAY_PRICE
}

enum ApiTokenStatus {
  ACTIVE
  DISABLED
  DELETED
}

enum UsageEventStatus {
  BILLABLE
  FREE
  FAILED
  METERING_UNKNOWN
}

enum WalletTransactionType {
  RECHARGE
  DEBIT
  REFUND
  ADMIN_ADJUST
}

enum RechargeCodeStatus {
  UNUSED
  USED
  DISABLED
}

enum NotificationChannelType {
  WEBHOOK
  EMAIL
}

enum NotificationEventType {
  TEST
  BALANCE_LOW
  SECURITY_ALERT
  SYSTEM_ANNOUNCEMENT
  PROMOTION
  MODEL_PRICE_UPDATE
}

enum NotificationDeliveryStatus {
  SENT
  FAILED
}

enum ReferralRewardStatus {
  PENDING
  SETTLED
  CANCELED
}

enum AsyncTaskKind {
  GENERIC
  IMAGE
}

enum AsyncTaskStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

model UserGroup {
  id            String             @id @default(uuid()) @db.Uuid
  code          String             @unique
  name          String
  multiplier    Decimal            @default(1.0) @db.Decimal(10, 4)
  status        GroupStatus        @default(ACTIVE)
  users         User[]
  modelAccesses ModelGroupAccess[]
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  @@map("user_groups")
}

model User {
  id                 String              @id @default(uuid()) @db.Uuid
  username           String              @unique
  passwordHash       String              @map("password_hash")
  status             UserStatus          @default(ACTIVE)
  role               UserRole            @default(USER)
  groupId            String              @map("group_id") @db.Uuid
  group              UserGroup           @relation(fields: [groupId], references: [id])
  inviteCode         String              @unique @map("invite_code")
  invitedByUserId    String?             @map("invited_by_user_id") @db.Uuid
  invitedBy          User?               @relation("UserInvites", fields: [invitedByUserId], references: [id])
  invitedUsers       User[]              @relation("UserInvites")
  timezone           String              @default("UTC")
  lastLoginAt        DateTime?           @map("last_login_at")
  lastLoginIp        String?             @map("last_login_ip")
  rateLimitRequestsPerMinute Int?        @map("rate_limit_requests_per_minute")
  riskLockedUntil    DateTime?           @map("risk_locked_until")
  riskReason         String?             @map("risk_reason")
  wallet             Wallet?
  sessions           Session[]
  apiTokens          ApiToken[]
  usageEvents        UsageEvent[]
  relayRateLimitEvents RelayRateLimitEvent[]
  walletTransactions WalletTransaction[]
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  deletedAt          DateTime?           @map("deleted_at")
  announcements      Announcement[]      @relation("AnnouncementCreator")
  adminActions       AdminAuditLog[]     @relation("AdminAuditActor")
  securityAuditLogs  SecurityAuditLog[]  @relation("SecurityAuditActor")
  requestLogs        RequestLog[]        @relation("RequestLogUser")
  upstreamProviders  UpstreamProvider[]  @relation("UpstreamProviderCreator")
  createdRechargeCodes RechargeCode[]    @relation("RechargeCodeCreator")
  usedRechargeCodes    RechargeCode[]    @relation("RechargeCodeUser")
  notificationPreference NotificationPreference?
  notificationChannels   NotificationChannel[]
  notificationDeliveries NotificationDelivery[]
  referralRewardsAsInviter ReferralReward[] @relation("ReferralRewardInviter")
  referralRewardsAsInvitee ReferralReward[] @relation("ReferralRewardInvitee")
  asyncTasks              AsyncTask[]

  @@index([groupId], map: "users_group_id_idx")
  @@index([invitedByUserId], map: "users_invited_by_user_id_idx")
  @@map("users")
}

model ApiToken {
  id            String                @id @default(uuid()) @db.Uuid
  userId        String                @map("user_id") @db.Uuid
  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  name          String
  tokenHash     String                @unique @map("token_hash")
  keyPreview    String                @map("key_preview")
  encryptedApiKey String?             @map("encrypted_api_key")
  status        ApiTokenStatus        @default(ACTIVE)
  quotaCents    Int?                  @map("quota_cents")
  usedCents     Int                   @default(0) @map("used_cents")
  expiresAt     DateTime?             @map("expires_at")
  note          String?
  lastUsedAt    DateTime?             @map("last_used_at")
  rateLimitRequestsPerMinute      Int?      @map("rate_limit_requests_per_minute")
  modelRateLimitRequestsPerMinute Int?      @map("model_rate_limit_requests_per_minute")
  ipRateLimitRequestsPerMinute    Int?      @map("ip_rate_limit_requests_per_minute")
  ipWhitelist                     String[]  @default([]) @map("ip_whitelist")
  activationTtlSeconds            Int?      @map("activation_ttl_seconds")
  activatedAt                     DateTime? @map("activated_at")
  activationExpiresAt             DateTime? @map("activation_expires_at")
  revokedAt     DateTime?             @map("revoked_at")
  deletedAt     DateTime?             @map("deleted_at")
  modelAccesses ApiTokenModelAccess[]
  usageEvents   UsageEvent[]
  relayRateLimitEvents RelayRateLimitEvent[]
  requestLogs   RequestLog[]           @relation("RequestLogToken")
  createdAt     DateTime              @default(now()) @map("created_at")
  updatedAt     DateTime              @updatedAt @map("updated_at")

  @@index([userId, status], map: "api_tokens_user_status_idx")
  @@index([expiresAt], map: "api_tokens_expires_at_idx")
  @@map("api_tokens")
}

model ApiTokenModelAccess {
  id         String     @id @default(uuid()) @db.Uuid
  apiTokenId String     @map("api_token_id") @db.Uuid
  apiToken   ApiToken   @relation(fields: [apiTokenId], references: [id], onDelete: Cascade)
  model      String
  modelPrice ModelPrice @relation(fields: [model], references: [model], onDelete: Cascade)
  createdAt  DateTime   @default(now()) @map("created_at")

  @@unique([apiTokenId, model], map: "api_token_model_accesses_token_model_key")
  @@index([model], map: "api_token_model_accesses_model_idx")
  @@map("api_token_model_accesses")
}

model Wallet {
  userId          String   @id @map("user_id") @db.Uuid
  balanceCents    Int      @default(0) @map("balance_cents")
  totalSpendCents Int      @default(0) @map("total_spend_cents")
  version         Int      @default(0)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("wallets")
}

model WalletTransaction {
  id                String                @id @default(uuid()) @db.Uuid
  userId            String                @map("user_id") @db.Uuid
  user              User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  type              WalletTransactionType
  amountCents       Int                   @map("amount_cents")
  balanceAfterCents Int                   @map("balance_after_cents")
  usageEventId      String?               @unique @map("usage_event_id") @db.Uuid
  usageEvent        UsageEvent?           @relation(fields: [usageEventId], references: [id], onDelete: Restrict)
  rechargeCodeId    String?               @unique @map("recharge_code_id") @db.Uuid
  rechargeCode      RechargeCode?         @relation(fields: [rechargeCodeId], references: [id], onDelete: Restrict)
  idempotencyKey    String                @unique @map("idempotency_key")
  createdAt         DateTime              @default(now()) @map("created_at")

  @@index([userId, createdAt], map: "wallet_transactions_user_created_at_idx")
  @@index([type], map: "wallet_transactions_type_idx")
  @@map("wallet_transactions")
}

model RechargeCode {
  id                String              @id @default(uuid()) @db.Uuid
  codeHash          String              @unique @map("code_hash")
  amountCents       Int                 @map("amount_cents")
  faceValueCnyCents Int                 @default(0) @map("face_value_cny_cents")
  status            RechargeCodeStatus  @default(UNUSED)
  createdByAdminId  String              @map("created_by_admin_id") @db.Uuid
  createdByAdmin    User                @relation("RechargeCodeCreator", fields: [createdByAdminId], references: [id], onDelete: Restrict)
  usedByUserId      String?             @map("used_by_user_id") @db.Uuid
  usedByUser        User?               @relation("RechargeCodeUser", fields: [usedByUserId], references: [id], onDelete: Restrict)
  usedAt            DateTime?           @map("used_at")
  walletTransaction WalletTransaction?
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  @@index([status, createdAt], map: "recharge_codes_status_created_at_idx")
  @@index([createdByAdminId, createdAt], map: "recharge_codes_created_by_admin_id_idx")
  @@index([usedByUserId, usedAt], map: "recharge_codes_used_by_user_id_idx")
  @@map("recharge_codes")
}

model NotificationPreference {
  id                         String   @id @default(uuid()) @db.Uuid
  userId                     String   @unique @map("user_id") @db.Uuid
  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balanceLowEnabled          Boolean  @default(false) @map("balance_low_enabled")
  balanceLowThresholdCents   Int?     @map("balance_low_threshold_cents")
  balanceLowLastNotifiedAt   DateTime? @map("balance_low_last_notified_at")
  securityAlertsEnabled      Boolean  @default(true) @map("security_alerts_enabled")
  systemAnnouncementsEnabled Boolean  @default(true) @map("system_announcements_enabled")
  promotionsEnabled          Boolean  @default(false) @map("promotions_enabled")
  modelPriceUpdatesEnabled   Boolean  @default(false) @map("model_price_updates_enabled")
  createdAt                  DateTime @default(now()) @map("created_at")
  updatedAt                  DateTime @updatedAt @map("updated_at")

  @@map("notification_preferences")
}

model NotificationChannel {
  id              String                      @id @default(uuid()) @db.Uuid
  userId          String                      @map("user_id") @db.Uuid
  user            User                        @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            NotificationChannelType
  name            String
  enabled         Boolean                     @default(false)
  targetPreview   String?                     @map("target_preview")
  encryptedTarget String?                     @map("encrypted_target")
  lastTestStatus  NotificationDeliveryStatus? @map("last_test_status")
  lastTestAt      DateTime?                   @map("last_test_at")
  lastTestError   String?                     @map("last_test_error")
  deliveries      NotificationDelivery[]
  createdAt       DateTime                    @default(now()) @map("created_at")
  updatedAt       DateTime                    @updatedAt @map("updated_at")

  @@unique([userId, type], map: "notification_channels_user_type_key")
  @@index([userId, enabled], map: "notification_channels_user_enabled_idx")
  @@map("notification_channels")
}

model NotificationDelivery {
  id             String                     @id @default(uuid()) @db.Uuid
  userId         String                     @map("user_id") @db.Uuid
  user           User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  channelId      String                     @map("channel_id") @db.Uuid
  channel        NotificationChannel        @relation(fields: [channelId], references: [id], onDelete: Cascade)
  eventType      NotificationEventType      @map("event_type")
  status         NotificationDeliveryStatus
  targetPreview  String?                    @map("target_preview")
  responseStatus Int?                       @map("response_status")
  errorMessage   String?                    @map("error_message")
  metadata       Json?                      @map("metadata")
  createdAt      DateTime                   @default(now()) @map("created_at")

  @@index([userId, createdAt], map: "notification_deliveries_user_created_at_idx")
  @@index([channelId, createdAt], map: "notification_deliveries_channel_created_at_idx")
  @@map("notification_deliveries")
}

model ReferralReward {
  id            String               @id @default(uuid()) @db.Uuid
  inviterUserId String               @map("inviter_user_id") @db.Uuid
  inviterUser   User                 @relation("ReferralRewardInviter", fields: [inviterUserId], references: [id], onDelete: Cascade)
  inviteeUserId String               @map("invitee_user_id") @db.Uuid
  inviteeUser   User                 @relation("ReferralRewardInvitee", fields: [inviteeUserId], references: [id], onDelete: Cascade)
  amountCents   Int                  @map("amount_cents")
  status        ReferralRewardStatus @default(PENDING)
  source        String?
  settledAt     DateTime?            @map("settled_at")
  createdAt     DateTime             @default(now()) @map("created_at")
  updatedAt     DateTime             @updatedAt @map("updated_at")

  @@index([inviterUserId, status, createdAt], map: "referral_rewards_inviter_status_created_at_idx")
  @@index([inviteeUserId, createdAt], map: "referral_rewards_invitee_created_at_idx")
  @@map("referral_rewards")
}

model Session {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  lastUsedAt DateTime  @default(now()) @map("last_used_at")
  createdAt  DateTime  @default(now()) @map("created_at")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "sessions_user_id_idx")
  @@index([expiresAt], map: "sessions_expires_at_idx")
  @@map("sessions")
}

model Announcement {
  id               String             @id @default(uuid()) @db.Uuid
  title            String
  content          String
  category         AnnouncementCategory @default(ANNOUNCEMENT)
  status           AnnouncementStatus @default(DRAFT)
  publishedAt      DateTime?          @map("published_at")
  createdByAdminId String             @map("created_by_admin_id") @db.Uuid
  createdByAdmin   User               @relation("AnnouncementCreator", fields: [createdByAdminId], references: [id])
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  @@index([createdByAdminId], map: "announcements_created_by_admin_id_idx")
  @@index([status], map: "announcements_status_idx")
  @@index([status, category, publishedAt], map: "announcements_public_feed_idx")
  @@map("announcements")
}

model AdminAuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  adminUserId    String   @map("admin_user_id") @db.Uuid
  adminUser      User     @relation("AdminAuditActor", fields: [adminUserId], references: [id])
  action         String
  targetType     String   @map("target_type")
  targetId       String?  @map("target_id") @db.Uuid
  beforeSnapshot Json?    @map("before_snapshot")
  afterSnapshot  Json?    @map("after_snapshot")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([adminUserId], map: "admin_audit_logs_admin_user_id_idx")
  @@index([createdAt], map: "admin_audit_logs_created_at_idx")
  @@map("admin_audit_logs")
}

model SecurityAuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  actorUser   User?    @relation("SecurityAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  action      String
  targetType  String   @map("target_type")
  targetId    String?  @map("target_id") @db.Uuid
  ipAddress   String?  @map("ip_address")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([actorUserId, createdAt], map: "security_audit_logs_actor_created_at_idx")
  @@index([action, createdAt], map: "security_audit_logs_action_created_at_idx")
  @@index([createdAt], map: "security_audit_logs_created_at_idx")
  @@map("security_audit_logs")
}

model AsyncTask {
  id                 String            @id @default(uuid()) @db.Uuid
  userId             String            @map("user_id") @db.Uuid
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  upstreamProviderId String?           @map("upstream_provider_id") @db.Uuid
  upstreamProvider   UpstreamProvider? @relation(fields: [upstreamProviderId], references: [id], onDelete: SetNull)
  externalTaskId     String            @map("external_task_id")
  platform           String
  kind               AsyncTaskKind     @default(GENERIC)
  status             AsyncTaskStatus   @default(QUEUED)
  model              String?
  prompt             String?
  progress           Int?
  resultJson         Json?             @map("result_json")
  errorMessage       String?           @map("error_message")
  submittedAt        DateTime          @default(now()) @map("submitted_at")
  startedAt          DateTime?         @map("started_at")
  completedAt        DateTime?         @map("completed_at")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  @@unique([platform, externalTaskId], map: "async_tasks_platform_external_task_id_key")
  @@index([userId, createdAt], map: "async_tasks_user_created_at_idx")
  @@index([userId, status], map: "async_tasks_user_status_idx")
  @@index([userId, kind, createdAt], map: "async_tasks_user_kind_created_at_idx")
  @@index([upstreamProviderId], map: "async_tasks_upstream_provider_id_idx")
  @@map("async_tasks")
}

model UpstreamProvider {
  id                  String                 @id @default(uuid()) @db.Uuid
  name                String                 @unique
  kind                UpstreamProviderKind   @default(GENERIC)
  baseUrl             String                 @map("base_url")
  encryptedApiKey     String                 @map("encrypted_api_key")
  apiKeyPreview       String                 @map("api_key_preview")
  status              UpstreamProviderStatus @default(ACTIVE)
  healthStatus        UpstreamHealthStatus   @default(UNKNOWN) @map("health_status")
  lastHealthCheckAt   DateTime?              @map("last_health_check_at")
  lastHealthLatencyMs Int?                   @map("last_health_latency_ms")
  lastHealthError     String?                @map("last_health_error")
  createdByAdminId    String                 @map("created_by_admin_id") @db.Uuid
  createdByAdmin      User                   @relation("UpstreamProviderCreator", fields: [createdByAdminId], references: [id])
  upstreamModels      UpstreamModel[]
  usageEvents         UsageEvent[]
  requestLogs         RequestLog[]         @relation("RequestLogUpstreamProvider")
  asyncTasks          AsyncTask[]
  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @updatedAt @map("updated_at")

  @@index([status], map: "upstream_providers_status_idx")
  @@index([healthStatus], map: "upstream_providers_health_status_idx")
  @@map("upstream_providers")
}

model ModelPrice {
  id                    String                @id @default(uuid()) @db.Uuid
  model                 String                @unique
  displayName           String?               @map("display_name")
  inputPriceCentsPer1k  Int                   @default(0) @map("input_price_cents_per_1k")
  outputPriceCentsPer1k Int                   @default(0) @map("output_price_cents_per_1k")
  modelMultiplier       Decimal               @default(1.0) @map("model_multiplier") @db.Decimal(10, 4)
  pricingMode           ModelPricingMode      @default(MANUAL) @map("pricing_mode")
  upstreamInputPricePerMillion  Decimal?      @map("upstream_input_price_per_million") @db.Decimal(12, 4)
  upstreamOutputPricePerMillion Decimal?      @map("upstream_output_price_per_million") @db.Decimal(12, 4)
  upstreamCurrency      String?               @map("upstream_currency")
  upstreamExchangeRate  Decimal?              @map("upstream_exchange_rate") @db.Decimal(12, 6)
  marginPercent         Decimal?              @map("margin_percent") @db.Decimal(8, 4)
  status                ModelStatus           @default(ACTIVE)
  groupAccesses         ModelGroupAccess[]
  upstreamModels        UpstreamModel[]       @relation("ModelUpstreamMappings")
  tokenAccesses         ApiTokenModelAccess[]
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")

  @@index([status], map: "model_prices_status_idx")
  @@map("model_prices")
}

model UpstreamModel {
  id             String           @id @default(uuid()) @db.Uuid
  providerId     String           @map("provider_id") @db.Uuid
  provider       UpstreamProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  publicModel    String           @map("public_model")
  modelPrice     ModelPrice       @relation("ModelUpstreamMappings", fields: [publicModel], references: [model], onDelete: Cascade)
  upstreamModel  String           @map("upstream_model")
  priority       Int              @default(1)
  timeoutMs      Int              @default(5000) @map("timeout_ms")
  upstreamPrompt String?          @map("upstream_prompt")
  status         ModelStatus      @default(ACTIVE)
  supportsStream Boolean          @default(true) @map("supports_stream")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  @@unique([providerId, publicModel, upstreamModel], map: "upstream_models_provider_public_upstream_key")
  @@index([providerId], map: "upstream_models_provider_id_idx")
  @@index([publicModel, status], map: "upstream_models_public_status_idx")
  @@index([publicModel, status, priority], map: "upstream_models_public_status_priority_idx")
  @@map("upstream_models")
}

model ModelGroupAccess {
  id           String     @id @default(uuid()) @db.Uuid
  modelPriceId String     @map("model_price_id") @db.Uuid
  modelPrice   ModelPrice @relation(fields: [modelPriceId], references: [id], onDelete: Cascade)
  groupId      String     @map("group_id") @db.Uuid
  group        UserGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now()) @map("created_at")

  @@unique([modelPriceId, groupId], map: "model_group_accesses_model_group_key")
  @@index([groupId], map: "model_group_accesses_group_id_idx")
  @@map("model_group_accesses")
}

model UsageEvent {
  id                 String             @id @default(uuid()) @db.Uuid
  requestId          String             @unique @map("request_id")
  userId             String             @map("user_id") @db.Uuid
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenId            String             @map("token_id") @db.Uuid
  token              ApiToken           @relation(fields: [tokenId], references: [id], onDelete: Restrict)
  upstreamProviderId String             @map("upstream_provider_id") @db.Uuid
  upstreamProvider   UpstreamProvider   @relation(fields: [upstreamProviderId], references: [id], onDelete: Restrict)
  model              String
  upstreamModel      String?            @map("upstream_model")
  promptTokens       Int                @default(0) @map("prompt_tokens")
  completionTokens   Int                @default(0) @map("completion_tokens")
  totalTokens        Int                @default(0) @map("total_tokens")
  costCents          Int                @default(0) @map("cost_cents")
  status             UsageEventStatus
  errorCode          String?            @map("error_code")
  priceSnapshot      Json               @map("price_snapshot")
  walletTransaction  WalletTransaction?
  createdAt          DateTime           @default(now()) @map("created_at")

  @@index([userId, createdAt], map: "usage_events_user_created_at_idx")
  @@index([tokenId, createdAt], map: "usage_events_token_created_at_idx")
  @@index([model, createdAt], map: "usage_events_model_created_at_idx")
  @@index([status, createdAt], map: "usage_events_status_created_at_idx")
  @@map("usage_events")
}

model RelayRateLimitEvent {
  id        String   @id @default(uuid()) @db.Uuid
  requestId String   @unique @map("request_id")
  userId    String   @map("user_id") @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenId   String   @map("token_id") @db.Uuid
  token     ApiToken @relation(fields: [tokenId], references: [id], onDelete: Cascade)
  model     String?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt], map: "relay_rate_limit_events_user_created_at_idx")
  @@index([tokenId, createdAt], map: "relay_rate_limit_events_token_created_at_idx")
  @@index([tokenId, model, createdAt], map: "relay_rate_limit_events_token_model_created_at_idx")
  @@index([tokenId, ipAddress, createdAt], map: "relay_rate_limit_events_token_ip_created_at_idx")
  @@map("relay_rate_limit_events")
}

model RequestLog {
  id                 String            @id @default(uuid()) @db.Uuid
  requestId          String            @unique @map("request_id")
  userId             String?           @map("user_id") @db.Uuid
  user               User?             @relation("RequestLogUser", fields: [userId], references: [id], onDelete: SetNull)
  tokenId            String?           @map("token_id") @db.Uuid
  token              ApiToken?         @relation("RequestLogToken", fields: [tokenId], references: [id], onDelete: SetNull)
  upstreamProviderId String?           @map("upstream_provider_id") @db.Uuid
  upstreamProvider   UpstreamProvider? @relation("RequestLogUpstreamProvider", fields: [upstreamProviderId], references: [id], onDelete: SetNull)
  method             String
  path               String
  model              String?
  statusCode         Int?              @map("status_code")
  errorCode          String?           @map("error_code")
  latencyMs          Int?              @map("latency_ms")
  upstreamLatencyMs  Int?              @map("upstream_latency_ms")
  upstreamStatusCode Int?              @map("upstream_status_code")
  upstreamStatus     String?           @map("upstream_status")
  createdAt          DateTime          @default(now()) @map("created_at")
  completedAt        DateTime?         @map("completed_at")

  @@index([userId, createdAt], map: "request_logs_user_created_at_idx")
  @@index([tokenId, createdAt], map: "request_logs_token_created_at_idx")
  @@index([statusCode, createdAt], map: "request_logs_status_created_at_idx")
  @@index([errorCode, createdAt], map: "request_logs_error_created_at_idx")
  @@map("request_logs")
}
